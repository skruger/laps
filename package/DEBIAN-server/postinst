#!/bin/sh
set -e

PACKAGE="laps-server"
USER="laps-server"
GROUP="laps-server"
HOME_DIR="/var/lib/$PACKAGE"
SHELL="/usr/sbin/nologin"  # or /bin/false

# $1 is the action (configure for install)
case "$1" in
  configure)
    # create group if missing
    if ! getent group "$GROUP" >/dev/null 2>&1; then
      addgroup --system --quiet "$GROUP"
    fi

    # create system user if missing
    if ! id -u "$USER" >/dev/null 2>&1; then
      adduser --system --quiet \
              --ingroup "$GROUP" \
              --home "$HOME_DIR" \
              --no-create-home \
              --shell "$SHELL" \
              --disabled-login \
              "$USER"
    fi

    # ensure ownership of package files
    #chown -R "$USER:$GROUP" "$HOME_DIR" || true


    chown "$USER:$GROUP" /etc/laps/config.yaml || true
    systemctl -q daemon-reload

    if [ ! -f "/etc/laps/config.yaml" ]; then
      # Create a default config file if it doesn't exist
      cp /usr/share/doc/laps-server/config.yaml /etc/laps/config.yaml
      chown "$USER:$GROUP" /etc/laps/config.yaml
    fi


    ;;

  *)
    # nothing for other actions
    ;;
esac

exit 0
